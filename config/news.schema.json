{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quant-pulse.local/schemas/canonical-news.json",
  "title": "Quant Pulse canonical news item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "source",
    "sourceTier",
    "url",
    "linkType",
    "publishedAt",
    "section",
    "category",
    "summary",
    "whyItMatters",
    "impact",
    "signalVsNoise",
    "priority",
    "relevanceScore",
    "scoreJustification",
    "tags",
    "dedupeKey"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Identificador único y estable"
    },
    "title": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "sourceTier": {
      "type": "string",
      "enum": ["primary", "tier_1", "tier_2", "tier_3", "unlisted"]
    },
    "url": { "type": "string", "format": "uri" },
    "linkType": {
      "type": "string",
      "enum": ["article", "source-section", "source-home"]
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 en UTC"
    },
    "scoredAt": {
      "type": "string",
      "format": "date-time",
      "description": "Marca temporal ISO 8601 UTC del momento en que se fijó el bloque de recencia"
    },
    "section": {
      "type": "string",
      "enum": ["Technology", "Crypto & Markets", "Macro"]
    },
    "category": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "whyItMatters": { "type": "string", "minLength": 1 },
    "impact": { "type": "string", "minLength": 1 },
    "signalVsNoise": { "type": "string", "enum": ["signal", "noise"] },
    "priority": { "type": "string", "enum": ["P1", "P2", "P3"] },
    "relevanceScore": { "type": "integer", "minimum": 0, "maximum": 100 },
    "scoreJustification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recency",
        "marketImpact",
        "structuralImpact",
        "sourceQuality",
        "crossValidation",
        "thematicRelevance",
        "rationale"
      ],
      "properties": {
        "recency": { "type": "integer", "minimum": 0, "maximum": 20 },
        "marketImpact": { "type": "integer", "minimum": 0, "maximum": 25 },
        "structuralImpact": { "type": "integer", "minimum": 0, "maximum": 20 },
        "sourceQuality": { "type": "integer", "minimum": 0, "maximum": 15 },
        "crossValidation": { "type": "integer", "minimum": 0, "maximum": 10 },
        "thematicRelevance": { "type": "integer", "minimum": 0, "maximum": 10 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 2,
      "maxItems": 6
    },
    "dedupeKey": { "type": "string", "minLength": 1 },
    "editorialOverride": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "reason"],
      "properties": {
        "field": {
          "type": "string",
          "enum": ["priority", "relevanceScore", "signalVsNoise", "section", "category", "scoreJustification.recency", "scoreJustification.sourceQuality"]
        },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "imageUrl": {
      "type": "string",
      "minLength": 1
    },
    "imageAlt": {
      "type": "string",
      "minLength": 1
    },
    "imageSource": {
      "type": "string",
      "minLength": 1
    },
    "featured": {
      "type": "boolean",
      "description": "Solo UI/app: destacado en feed; no sustituye priority ni score"
    }
  }
}
